# Google OAuth (from Google Cloud Console → APIs & Services → Credentials)
GOOG_CLIENT_ID=your-google-client-id
GOOG_CLIENT_SECRET=your-google-client-secret

# TikTok OAuth (from developers.tiktok.com → your app → App info)
TIKTOK_CLIENT_KEY=your-tiktok-client-key
TIKTOK_CLIENT_SECRET=your-tiktok-client-secret

# Neon.tech PostgreSQL connection string
NEON_DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require

# Session secret — generate with: openssl rand -base64 48
SESSION_SECRET=change-this-to-a-long-random-string

# Your app's public URL (used for OAuth callbacks)
APP_URL=https://storyload.ru

# Port (default 3000; use 3001 behind Nginx)
PORT=3001
